<?xml version="1.0" encoding="utf-8"?>
<!-- res/values-v31/themes.xml  (Android 12+ splash screen)
     Apply this theme as your launch theme in AndroidManifest (android:theme).
     The splash shows the mark on the dark brand background, then hands off to your app. -->
<resources>
    <style name="Theme.SolarMonitor.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_bg_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.SolarMonitor</item>
    </style>
</resources>
