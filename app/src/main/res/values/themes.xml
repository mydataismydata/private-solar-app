<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose draws the UI; this only styles the window/system bars. Dark-parented with a
         dark window background so there is no white flash before Compose takes over. -->
    <style name="Theme.SolarMonitor" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/brand_bg_dark</item>
        <item name="android:statusBarColor">@color/brand_bg_dark</item>
    </style>

    <!-- Launch (splash) theme. Backported to all API levels by androidx core-splashscreen.
         v31+ overrides live in values-v31/themes.xml. -->
    <style name="Theme.SolarMonitor.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_bg_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.SolarMonitor</item>
    </style>
</resources>
